@model ITIMVCSECPROJ.Helpers.PaginatedList<ITIMVCSECPROJ.ViewModels.CourseViewModel.CourseVM>

@{
    ViewData["Title"] = "Courses List";

    string searched = Context.Request.Query["searched"];
}

<div class="container mt-4">

    <div class="card shadow-sm border-0">

        <!-- Header -->
        <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
            <h3 class="mb-0">Courses List</h3>

            <a asp-action="Create" class="btn btn-light btn-sm">
                Add Course
            </a>
        </div>

        <div class="card-body">

            <!-- Search Form -->
            <form asp-action="Search" method="get" class="mb-4">

                <div class="row g-2">

                    <div class="col-md-10">
                        <input type="text"
                               name="searched"
                               value="@searched"
                               class="form-control"
                               placeholder="Search by course name..." />
                    </div>

                    <div class="col-md-2 d-grid">
                        <button type="submit" class="btn btn-dark">
                            Search
                        </button>
                    </div>

                </div>

            </form>

            @if (Model.Items.Any())
            {
                <div class="table-responsive">

                    <table class="table table-hover table-bordered align-middle text-center">

                        <thead class="table-light">
                            <tr>
                                <th>ID</th>
                                <th>Course Name</th>
                                <th>Department</th>
                                <th width="220">Actions</th>
                            </tr>
                        </thead>

                        <tbody>
                            @foreach (var item in Model.Items)
                            {
                                <tr>

                                    <td>@item.CourseID</td>

                                    <td class="fw-semibold">
                                        @item.CourseName
                                    </td>

                                    <td>
                                        @(item.DepartmentName ?? "No Department")
                                    </td>

                                    <td>

                                        <a asp-action="Detail"
                                           asp-route-id="@item.CourseID"
                                           class="btn btn-info btn-sm text-white">
                                            Details
                                        </a>

                                        <a asp-action="Edit"
                                           asp-route-id="@item.CourseID"
                                           class="btn btn-warning btn-sm">
                                            Edit
                                        </a>

                                        <a asp-action="Delete"
                                           asp-route-id="@item.CourseID"
                                           class="btn btn-danger btn-sm">
                                            Delete
                                        </a>

                                    </td>

                                </tr>
                            }
                        </tbody>

                    </table>

                </div>

                <!-- Pagination -->
                <nav class="mt-4">

                    <ul class="pagination justify-content-center">

                        <!-- Previous -->
                        <li class="page-item @(Model.HasPrevious ? "" : "disabled")">

                            <a class="page-link"
                               asp-action="@(string.IsNullOrEmpty(searched) ? "Index" : "Search")"
                               asp-route-page="@(Model.CurrentPage - 1)"
                               asp-route-searched="@searched">
                                Previous
                            </a>

                        </li>

                        <!-- Page Numbers -->
                        @for (int i = 1; i <= Model.TotalPages; i++)
                        {
                            <li class="page-item @(i == Model.CurrentPage ? "active" : "")">

                                <a class="page-link"
                                   asp-action="@(string.IsNullOrEmpty(searched) ? "Index" : "Search")"
                                   asp-route-page="@i"
                                   asp-route-searched="@searched">
                                    @i
                                </a>

                            </li>
                        }

                        <!-- Next -->
                        <li class="page-item @(Model.HasNext ? "" : "disabled")">

                            <a class="page-link"
                               asp-action="@(string.IsNullOrEmpty(searched) ? "Index" : "Search")"
                               asp-route-page="@(Model.CurrentPage + 1)"
                               asp-route-searched="@searched">
                                Next
                            </a>

                        </li>

                    </ul>

                </nav>
            }
            else
            {
                <div class="alert alert-warning text-center">
                    No Courses Found
                </div>
            }

        </div>

    </div>

</div>